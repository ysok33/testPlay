{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/wp-admin/site-editor.php",
  "preferredVersions": {
    "php": "8.2",
    "wp": "6.5"
  },
  "features": {
    "networking": true
  },
  "steps": [
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "SIgroup株式会社",
        "blogdescription": "営業力と人財力で、現場の成果まで設計する。"
      }
    },
    {
      "step": "login",
      "username": "admin",
      "password": "password"
    },
    {
      "step": "installTheme",
      "themeZipFile": {
        "resource": "url",
        "url": "https://raw.githubusercontent.com/ysok33/testPlay/main/sigroup-block-theme.zip"
      }
    },
    {
      "step": "activateTheme",
      "themeFolderName": "si-group-block-theme"
    }
  ]
}
